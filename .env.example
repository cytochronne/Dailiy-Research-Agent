# Copy to .env for local development. Do not commit real secrets.

# LLM provider settings.
# Set to 'fake' for deterministic local tests.
# 'openai' and 'live' are treated as hosted live APIs.
# Any other non-fake value is treated as a custom OpenAI-compatible API provider.
LLM_PROVIDER=openai
# Required for 'openai' and 'live'. Optional only for local gateways that do not require auth.
LLM_API_KEY=
LLM_MODEL=gpt-5-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_COMPLETIONS_PATH=/chat/completions
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1.0
LLM_OUTPUT_RETRIES=1
LLM_BRIEFING_MAX_RETRIES=4
LLM_BRIEFING_RETRY_BACKOFF_SECONDS=1.5
LLM_BRIEFING_OUTPUT_RETRIES=2

# Embedding provider settings for semantic seed recommendation.
# Set to 'fake' for deterministic local semantic tests and demos.
# 'openai' and 'live' require EMBEDDING_API_KEY.
# Any other non-fake value is treated as a custom OpenAI-compatible embeddings API.
EMBEDDING_PROVIDER=openai
# Primary embedding credential. OPENAI_API_KEY is reused only when explicitly opted in below.
EMBEDDING_API_KEY=
EMBEDDING_REUSE_OPENAI_API_KEY=false
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_PATH=/embeddings
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_BACKOFF_SECONDS=1.0
# Leave blank for provider default dimensions, or set a positive integer.
EMBEDDING_DIMENSIONS=
# Cache storage is added in the semantic cache unit; readiness reports this flag now.
EMBEDDING_CACHE_ENABLED=true

# Local SQLite database path used by later units.
DAILY_ARXIV_DB_PATH=data/daily_arxiv.sqlite3

# arXiv access pacing. Keep polite defaults.
ARXIV_REQUEST_DELAY_SECONDS=3

# Search planning and retrieval budget defaults.
# DAILY_ARXIV_SEARCH_MODE may be 'broad' or 'strict'.
DAILY_ARXIV_SEARCH_MODE=broad
# Candidate pool size is the pre-ranking retrieval target. Top K is configured per run.
DAILY_ARXIV_CANDIDATE_POOL_SIZE=100
ARXIV_PAGE_SIZE=50
ARXIV_MAX_REQUESTS_PER_SEARCH=4
# QUERY_PLANNER_MODE may be 'auto', 'deterministic', or 'llm'.
# Live LLM planner mode sends query text and filters to the configured provider.
# Local caches and debug traces can contain topics or query variants; clear demo data before sharing.
QUERY_PLANNER_MODE=auto
